{
  "info": {
    "name": "Hybrid Token Auth Prototype",
    "_postman_id": "7f53c74c-6d6e-4f2e-a682-f68ee18d0f74",
    "description": "Collection for the academic hybrid token authentication prototype.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Gateway Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{gatewayBaseUrl}}/health",
          "host": ["{{gatewayBaseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Runtime Config",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{gatewayBaseUrl}}/api/config",
          "host": ["{{gatewayBaseUrl}}"],
          "path": ["api", "config"]
        }
      }
    },
    {
      "name": "OIDC Exchange",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"{{authorizationCode}}\",\n  \"codeVerifier\": \"{{codeVerifier}}\"\n}"
        },
        "url": {
          "raw": "{{gatewayBaseUrl}}/api/oidc/exchange",
          "host": ["{{gatewayBaseUrl}}"],
          "path": ["api", "oidc", "exchange"]
        }
      }
    },
    {
      "name": "Local Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "X-Client-Id",
            "value": "{{clientId}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"demo\",\n  \"password\": \"Password123!\",\n  \"externalAccessToken\": \"{{externalAccessToken}}\",\n  \"idToken\": \"{{idToken}}\",\n  \"oidcNonce\": \"{{oidcNonce}}\"\n}"
        },
        "url": {
          "raw": "{{gatewayBaseUrl}}/api/auth/login",
          "host": ["{{gatewayBaseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "Protected Profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{internalAccessToken}}"
          }
        ],
        "url": {
          "raw": "{{gatewayBaseUrl}}/api/protected/profile",
          "host": ["{{gatewayBaseUrl}}"],
          "path": ["api", "protected", "profile"]
        }
      }
    },
    {
      "name": "Refresh Access Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "X-CSRF-Token",
            "value": "{{csrfToken}}"
          }
        ],
        "url": {
          "raw": "{{gatewayBaseUrl}}/api/auth/refresh",
          "host": ["{{gatewayBaseUrl}}"],
          "path": ["api", "auth", "refresh"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "gatewayBaseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "clientId",
      "value": "bachelor-client"
    }
  ]
}
